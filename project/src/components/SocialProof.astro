---
const { t, lang } = Astro.props;

const testimonials = [
	{
		id: 1,
		name: 'Marie Dubois',
		location: 'Plateau-Mont-Royal',
		date: lang === 'fr' ? 'Janvier 2025' : 'January 2025',
		rating: 5,
		text: lang === 'fr'
			? 'Service impeccable du début à la fin. L\'équipe était professionnelle, ponctuelle et a laissé ma maison impeccable. La qualité de la finition dépasse mes attentes.'
			: 'Impeccable service from start to finish. The team was professional, punctual, and left my house spotless. The finish quality exceeds my expectations.',
		verified: true,
		platform: 'Google'
	},
	{
		id: 2,
		name: 'John Smith',
		location: 'NDG',
		date: lang === 'fr' ? 'Décembre 2024' : 'December 2024',
		rating: 5,
		text: lang === 'fr'
			? 'J\'ai demandé à voir leurs licences RBQ et APCHQ avant de signer. Tout était en ordre. C\'est rassurant de travailler avec un entrepreneur légitime.'
			: 'I asked to see their RBQ and APCHQ licences before signing. Everything was in order. It\'s reassuring to work with a legitimate contractor.',
		verified: true,
		platform: 'Facebook'
	},
	{
		id: 3,
		name: 'Sophie Tremblay',
		location: 'Rosemont',
		date: lang === 'fr' ? 'Novembre 2024' : 'November 2024',
		rating: 5,
		text: lang === 'fr'
			? 'Prix transparent, pas de frais cachés. La soumission détaillée m\'a permis de comprendre exactement ce que je payais. Aucune mauvaise surprise à la fin.'
			: 'Transparent pricing, no hidden fees. The detailed quote helped me understand exactly what I was paying for. No bad surprises at the end.',
		verified: true,
		platform: 'Google'
	}
];
---

<section id="testimonials" class="py-20 md:py-32 bg-gradient-to-b from-white to-neutral-50">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center max-w-3xl mx-auto mb-16">
			<div class="inline-flex items-center space-x-2 px-4 py-2 bg-accent-50 rounded-full mb-6">
				<svg class="w-4 h-4 text-accent-600" fill="currentColor" viewBox="0 0 20 20">
					<path d="M2 10.5a1.5 1.5 0 113 0v6a1.5 1.5 0 01-3 0v-6zM6 10.333v5.43a2 2 0 001.106 1.79l.05.025A4 4 0 008.943 18h5.416a2 2 0 001.962-1.608l1.2-6A2 2 0 0015.56 8H12V4a2 2 0 00-2-2 1 1 0 00-1 1v.667a4 4 0 01-.8 2.4L6.8 7.933a4 4 0 00-.8 2.4z"/>
				</svg>
				<span class="text-sm font-semibold text-accent-700">{lang === 'fr' ? 'Pilier 4' : 'Pillar 4'}: ProveSocialProof</span>
			</div>
			<h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-neutral-900 mb-4">
				{t.social.title}
			</h2>
			<p class="text-xl text-neutral-600 leading-relaxed">
				{t.social.subtitle}
			</p>
		</div>

		<div class="grid md:grid-cols-3 gap-8 mb-12">
			{testimonials.map((testimonial) => (
				<div class="group bg-white rounded-2xl p-6 border border-neutral-200 hover:border-primary-300 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
					<div class="flex items-start justify-between mb-4">
						<div class="flex-1">
							<div class="flex items-center space-x-1 mb-2">
								{Array.from({ length: testimonial.rating }).map(() => (
									<svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
										<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
									</svg>
								))}
							</div>
							<h3 class="font-semibold text-neutral-900 mb-1">{testimonial.name}</h3>
							<p class="text-sm text-neutral-500">{testimonial.location} • {testimonial.date}</p>
						</div>
						{testimonial.verified && (
							<div class="flex-shrink-0">
								<div class="inline-flex items-center px-2.5 py-1 bg-primary-100 rounded-full">
									<svg class="w-3.5 h-3.5 text-primary-600 mr-1" fill="currentColor" viewBox="0 0 20 20">
										<path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
									</svg>
									<span class="text-xs font-semibold text-primary-700">{t.social.verified}</span>
								</div>
							</div>
						)}
					</div>

					<p class="text-neutral-700 leading-relaxed mb-4">{testimonial.text}</p>

					<div class="flex items-center justify-between pt-4 border-t border-neutral-200">
						<div class="flex items-center space-x-2">
							<div class="w-6 h-6 rounded bg-neutral-200 flex items-center justify-center">
								<svg class="w-4 h-4 text-neutral-600" fill="currentColor" viewBox="0 0 20 20">
									{testimonial.platform === 'Google' ? (
										<path d="M10 0C4.477 0 0 4.477 0 10c0 4.991 3.657 9.128 8.438 9.879V12.89h-2.54V10h2.54V7.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V10h2.773l-.443 2.89h-2.33v6.989C16.343 19.128 20 14.99 20 10c0-5.523-4.477-10-10-10z"/>
									) : (
										<path d="M10 0C4.477 0 0 4.477 0 10c0 4.991 3.657 9.128 8.438 9.879V12.89h-2.54V10h2.54V7.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V10h2.773l-.443 2.89h-2.33v6.989C16.343 19.128 20 14.99 20 10c0-5.523-4.477-10-10-10z"/>
									)}
								</svg>
							</div>
							<span class="text-xs text-neutral-600 font-medium">{testimonial.platform}</span>
						</div>
						<button class="text-primary-600 hover:text-primary-700 text-sm font-medium group-hover:underline">
							{lang === 'fr' ? 'Voir l\'avis complet' : 'View full review'} →
						</button>
					</div>
				</div>
			))}
		</div>

		<div class="grid md:grid-cols-2 gap-8 mb-12">
			<div class="bg-gradient-to-br from-primary-50 to-white rounded-3xl p-8 border border-primary-100">
				<div class="flex items-start space-x-4 mb-6">
					<div class="flex-shrink-0 w-16 h-16 rounded-xl bg-primary-100 flex items-center justify-center">
						<svg class="w-8 h-8 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
							<path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
						</svg>
					</div>
					<div>
						<h3 class="font-display text-xl font-semibold text-neutral-900 mb-2">
							{lang === 'fr' ? 'Avis vérifiés uniquement' : 'Verified reviews only'}
						</h3>
						<p class="text-neutral-600 leading-relaxed">
							{lang === 'fr'
								? 'Tous nos avis proviennent directement de Google et Facebook. Pas de témoignages inventés ou anonymes.'
								: 'All our reviews come directly from Google and Facebook. No fake or anonymous testimonials.'}
						</p>
					</div>
				</div>
				<div class="flex items-center space-x-4">
					<div class="flex items-center space-x-1">
						<svg class="w-6 h-6 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
							<path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
						</svg>
						<span class="text-2xl font-bold text-neutral-900">4.9/5</span>
					</div>
					<div class="text-sm text-neutral-600">
						{lang === 'fr' ? 'Basé sur' : 'Based on'} 47+ {lang === 'fr' ? 'avis' : 'reviews'}
					</div>
				</div>
			</div>

			<div class="bg-gradient-to-br from-accent-50 to-white rounded-3xl p-8 border border-accent-100">
				<div class="flex items-start space-x-4 mb-6">
					<div class="flex-shrink-0 w-16 h-16 rounded-xl bg-accent-100 flex items-center justify-center">
						<svg class="w-8 h-8 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
						</svg>
					</div>
					<div>
						<h3 class="font-display text-xl font-semibold text-neutral-900 mb-2">
							{lang === 'fr' ? 'Témoignages vidéo' : 'Video testimonials'}
						</h3>
						<p class="text-neutral-600 leading-relaxed mb-4">
							{lang === 'fr'
								? 'Regardez nos clients partager leurs expériences en personne. Des histoires authentiques de vrais projets.'
								: 'Watch our clients share their experiences in person. Authentic stories from real projects.'}
						</p>
						<button class="inline-flex items-center text-accent-700 hover:text-accent-800 font-semibold text-sm">
							<svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
								<path d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z"/>
							</svg>
							{lang === 'fr' ? 'Voir les vidéos' : 'Watch videos'}
						</button>
					</div>
				</div>
			</div>
		</div>

		<div class="text-center">
			<a href={`${lang === 'en' ? '/en' : ''}#quote`}
			   class="inline-flex items-center px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-xl transition-all hover:shadow-lg hover:shadow-primary-500/30 hover:-translate-y-0.5">
				<span>{t.social.cta}</span>
				<svg class="ml-2 w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
					<path d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z"/>
				</svg>
			</a>
		</div>
	</div>
</section>
