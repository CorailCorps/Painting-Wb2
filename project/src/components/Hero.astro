---
const { t, lang } = Astro.props;
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden bg-gradient-to-br from-neutral-50 via-white to-primary-50/30">
	<div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(14,165,233,0.08),transparent_50%)]"></div>
	<div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_80%,rgba(251,191,36,0.06),transparent_50%)]"></div>

	<div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
		<div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
			<div class="space-y-8 animate-fade-in">
				<div class="inline-flex items-center space-x-2 px-4 py-2 bg-primary-100/80 backdrop-blur-sm rounded-full border border-primary-200">
					<svg class="w-4 h-4 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
						<path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
					</svg>
					<span class="text-sm font-medium text-primary-700">RBQ • NEQ • APCHQ</span>
				</div>

				<div class="space-y-4">
					<h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-neutral-900 leading-tight tracking-tight">
						{t.hero.title}
					</h1>
					<p class="text-2xl sm:text-3xl font-semibold text-primary-600">
						{t.hero.subtitle}
					</p>
				</div>

				<p class="text-lg text-neutral-600 leading-relaxed max-w-xl">
					{t.hero.description}
				</p>

				<div class="flex flex-col sm:flex-row gap-4 pt-4">
					<a href={`${lang === 'en' ? '/en' : ''}#quote`}
					   class="group inline-flex items-center justify-center px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-xl transition-all hover:shadow-xl hover:shadow-primary-500/40 hover:-translate-y-1">
						<span>{t.hero.cta}</span>
						<svg class="ml-2 w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
						</svg>
					</a>
					<a href={`${lang === 'en' ? '/en' : ''}#legitimacy`}
					   class="group inline-flex items-center justify-center px-8 py-4 bg-white hover:bg-neutral-50 text-neutral-700 font-semibold rounded-xl border-2 border-neutral-200 hover:border-primary-200 transition-all">
						<svg class="mr-2 w-5 h-5 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
						</svg>
						<span>{t.hero.ctaSecondary}</span>
					</a>
				</div>

				<div class="flex flex-wrap items-center gap-6 pt-6 border-t border-neutral-200">
					<div class="flex items-center space-x-3">
						<div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center">
							<svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
							</svg>
						</div>
						<div>
							<p class="text-sm font-semibold text-neutral-900">{lang === 'fr' ? 'Assuré' : 'Insured'}</p>
							<p class="text-xs text-neutral-600">{lang === 'fr' ? 'Responsabilité complète' : 'Full liability'}</p>
						</div>
					</div>
					<div class="flex items-center space-x-3">
						<div class="w-12 h-12 rounded-full bg-accent-100 flex items-center justify-center">
							<svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
							</svg>
						</div>
						<div>
							<p class="text-sm font-semibold text-neutral-900">{lang === 'fr' ? 'Transparent' : 'Transparent'}</p>
							<p class="text-xs text-neutral-600">{lang === 'fr' ? 'Prix clairs' : 'Clear pricing'}</p>
						</div>
					</div>
					<div class="flex items-center space-x-3">
						<div class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center">
							<svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
							</svg>
						</div>
						<div>
							<p class="text-sm font-semibold text-neutral-900">{lang === 'fr' ? 'Local' : 'Local'}</p>
							<p class="text-xs text-neutral-600">Montréal</p>
						</div>
					</div>
				</div>
			</div>

			<div class="relative lg:pl-8">
				<div class="relative rounded-2xl overflow-hidden shadow-2xl transform lg:translate-x-8">
					<div class="aspect-[4/5] bg-gradient-to-br from-neutral-200 to-neutral-300 flex items-center justify-center">
						<div class="text-center p-8">
							<svg class="w-24 h-24 mx-auto text-neutral-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
							</svg>
							<p class="text-sm text-neutral-500">[{lang === 'fr' ? 'Photo de projet à ajouter' : 'Project photo to be added'}]</p>
						</div>
					</div>
				</div>
				<div class="absolute -bottom-6 -left-6 w-32 h-32 bg-primary-500/10 rounded-full blur-3xl"></div>
				<div class="absolute -top-6 -right-6 w-40 h-40 bg-accent-500/10 rounded-full blur-3xl"></div>
			</div>
		</div>
	</div>
</section>

<style>
	@keyframes fade-in {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in {
		animation: fade-in 0.8s ease-out;
	}
</style>
