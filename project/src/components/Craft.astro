---
const { t, lang } = Astro.props;

const projects = [
	{
		id: 1,
		title: lang === 'fr' ? 'Salon moderne - Plateau' : 'Modern living room - Plateau',
		description: lang === 'fr' ? 'Finition impeccable avec Sherwin-Williams Emerald' : 'Flawless finish with Sherwin-Williams Emerald'
	},
	{
		id: 2,
		title: lang === 'fr' ? 'Cuisine ouverte - Rosemont' : 'Open kitchen - Rosemont',
		description: lang === 'fr' ? 'Préparation méticuleuse et 3 couches' : 'Meticulous prep and 3 coats'
	},
	{
		id: 3,
		title: lang === 'fr' ? 'Extérieur duplex - Verdun' : 'Duplex exterior - Verdun',
		description: lang === 'fr' ? 'Résistance aux intempéries garantie' : 'Weather resistance guaranteed'
	},
	{
		id: 4,
		title: lang === 'fr' ? 'Chambres à coucher - Outremont' : 'Bedrooms - Outremont',
		description: lang === 'fr' ? 'Couleurs personnalisées et finitions douces' : 'Custom colors and smooth finishes'
	}
];
---

<section id="craft" class="py-20 md:py-32 bg-white">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center max-w-3xl mx-auto mb-16">
			<div class="inline-flex items-center space-x-2 px-4 py-2 bg-primary-50 rounded-full mb-6">
				<svg class="w-4 h-4 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
					<path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
				</svg>
				<span class="text-sm font-semibold text-primary-700">{lang === 'fr' ? 'Pilier 2' : 'Pillar 2'}: ShowCraftAndProcess</span>
			</div>
			<h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-neutral-900 mb-4">
				{t.craft.title}
			</h2>
			<p class="text-xl text-neutral-600 leading-relaxed">
				{t.craft.subtitle}
			</p>
		</div>

		<div class="grid sm:grid-cols-2 gap-8 mb-16">
			{projects.map((project) => (
				<div class="group relative bg-white rounded-2xl overflow-hidden border border-neutral-200 hover:border-primary-300 hover:shadow-2xl transition-all duration-300">
					<div class="relative aspect-[4/3] bg-gradient-to-br from-neutral-200 to-neutral-300 overflow-hidden">
						<div class="absolute inset-0 flex items-center justify-center">
							<svg class="w-16 h-16 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
							</svg>
						</div>
						<div class="absolute top-4 left-4 bg-white/95 backdrop-blur px-3 py-1.5 rounded-full text-xs font-semibold text-neutral-700">
							{t.craft.beforeAfter}
						</div>
						<div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
							<div class="absolute bottom-4 left-4 right-4">
								<button class="w-full px-4 py-2 bg-white hover:bg-neutral-100 text-neutral-900 font-medium rounded-lg transition-colors flex items-center justify-center space-x-2">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/>
									</svg>
									<span>{lang === 'fr' ? 'Voir en détail' : 'View details'}</span>
								</button>
							</div>
						</div>
					</div>
					<div class="p-6">
						<h3 class="font-display text-lg font-semibold text-neutral-900 mb-2">{project.title}</h3>
						<p class="text-sm text-neutral-600">{project.description}</p>
					</div>
				</div>
			))}
		</div>

		<div class="grid md:grid-cols-2 gap-8 mb-12">
			<div class="bg-gradient-to-br from-primary-50 to-white rounded-3xl p-8 border border-primary-100">
				<div class="flex items-start space-x-4">
					<div class="flex-shrink-0 w-16 h-16 rounded-xl bg-primary-100 flex items-center justify-center">
						<svg class="w-8 h-8 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
						</svg>
					</div>
					<div>
						<h3 class="font-display text-xl font-semibold text-neutral-900 mb-3">
							{lang === 'fr' ? 'Photos haute résolution réelles' : 'Real high-resolution photos'}
						</h3>
						<p class="text-neutral-600 leading-relaxed mb-4">
							{lang === 'fr'
								? 'Chaque photo montre notre travail authentique. Pas de retouches, pas de mises en scène. Juste la qualité de notre finition.'
								: 'Every photo shows our authentic work. No edits, no staging. Just the quality of our finish.'}
						</p>
						<ul class="space-y-2">
							<li class="flex items-center text-sm text-neutral-700">
								<svg class="w-4 h-4 mr-2 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
								{lang === 'fr' ? 'Gros plans de finition' : 'Finish close-ups'}
							</li>
							<li class="flex items-center text-sm text-neutral-700">
								<svg class="w-4 h-4 mr-2 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
								{lang === 'fr' ? 'Même angle avant/après' : 'Same angle before/after'}
							</li>
							<li class="flex items-center text-sm text-neutral-700">
								<svg class="w-4 h-4 mr-2 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
								{lang === 'fr' ? 'Date et lieu affichés' : 'Date and location shown'}
							</li>
						</ul>
					</div>
				</div>
			</div>

			<div class="bg-gradient-to-br from-accent-50 to-white rounded-3xl p-8 border border-accent-100">
				<div class="flex items-start space-x-4">
					<div class="flex-shrink-0 w-16 h-16 rounded-xl bg-accent-100 flex items-center justify-center">
						<svg class="w-8 h-8 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
						</svg>
					</div>
					<div>
						<h3 class="font-display text-xl font-semibold text-neutral-900 mb-3">
							{t.craft.materials}
						</h3>
						<p class="text-neutral-600 leading-relaxed mb-4">
							{lang === 'fr'
								? 'Nous utilisons exclusivement des produits Sherwin-Williams pour garantir durabilité et finition supérieure.'
								: 'We exclusively use Sherwin-Williams products to guarantee durability and superior finish.'}
						</p>
						<ul class="space-y-2">
							<li class="flex items-center text-sm text-neutral-700">
								<svg class="w-4 h-4 mr-2 text-accent-600" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
								Emerald Interior
							</li>
							<li class="flex items-center text-sm text-neutral-700">
								<svg class="w-4 h-4 mr-2 text-accent-600" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
								Duration Exterior
							</li>
							<li class="flex items-center text-sm text-neutral-700">
								<svg class="w-4 h-4 mr-2 text-accent-600" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
								</svg>
								{lang === 'fr' ? 'Garantie du fabricant' : 'Manufacturer warranty'}
							</li>
						</ul>
					</div>
				</div>
			</div>
		</div>

		<div class="text-center">
			<a href={`${lang === 'en' ? '/en' : ''}#quote`}
			   class="inline-flex items-center px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-xl transition-all hover:shadow-lg hover:shadow-primary-500/30 hover:-translate-y-0.5">
				<span>{t.craft.cta}</span>
				<svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
				</svg>
			</a>
		</div>
	</div>
</section>
