---
const { t, lang } = Astro.props;
---

<section id="quote" class="py-20 md:py-32 bg-gradient-to-br from-primary-600 to-primary-800 relative overflow-hidden">
	<div class="absolute inset-0 opacity-10">
		<div class="absolute top-0 left-0 w-96 h-96 bg-white rounded-full blur-3xl"></div>
		<div class="absolute bottom-0 right-0 w-96 h-96 bg-accent-400 rounded-full blur-3xl"></div>
	</div>

	<div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="grid lg:grid-cols-5 gap-12 items-center">
			<div class="lg:col-span-2 text-white">
				<h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold mb-6">
					{lang === 'fr' ? 'Obtenez votre soumission détaillée' : 'Get your detailed quote'}
				</h2>
				<p class="text-xl text-primary-100 leading-relaxed mb-8">
					{lang === 'fr'
						? 'Prix transparent, portée claire, aucune surprise. Réponse sous 24h.'
						: 'Transparent pricing, clear scope, no surprises. Response within 24h.'}
				</p>

				<div class="space-y-4">
					<div class="flex items-start space-x-3">
						<svg class="w-6 h-6 text-accent-300 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
						</svg>
						<div>
							<p class="font-semibold text-white">{lang === 'fr' ? 'Évaluation sur place gratuite' : 'Free on-site assessment'}</p>
							<p class="text-primary-100 text-sm">{lang === 'fr' ? 'Nous venons chez vous pour voir le projet' : 'We come to your place to see the project'}</p>
						</div>
					</div>
					<div class="flex items-start space-x-3">
						<svg class="w-6 h-6 text-accent-300 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
						</svg>
						<div>
							<p class="font-semibold text-white">{lang === 'fr' ? 'Soumission détaillée' : 'Detailed quote'}</p>
							<p class="text-primary-100 text-sm">{lang === 'fr' ? 'Chaque ligne clairement expliquée' : 'Every line clearly explained'}</p>
						</div>
					</div>
					<div class="flex items-start space-x-3">
						<svg class="w-6 h-6 text-accent-300 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
						</svg>
						<div>
							<p class="font-semibold text-white">{lang === 'fr' ? 'Aucun engagement' : 'No commitment'}</p>
							<p class="text-primary-100 text-sm">{lang === 'fr' ? 'La soumission est gratuite' : 'The quote is free'}</p>
						</div>
					</div>
				</div>
			</div>

			<div class="lg:col-span-3">
				<div class="bg-white rounded-3xl shadow-2xl p-8 md:p-10">
					<div class="flex items-center justify-between mb-8">
						<h3 class="font-display text-2xl font-bold text-neutral-900">
							{lang === 'fr' ? 'Formulaire de soumission' : 'Quote request form'}
						</h3>
						<div class="flex items-center space-x-2 px-3 py-1.5 bg-primary-100 rounded-full">
							<div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
							<span class="text-xs font-semibold text-primary-700">{lang === 'fr' ? 'Réponse rapide' : 'Quick response'}</span>
						</div>
					</div>

					<form class="space-y-6">
						<div class="grid sm:grid-cols-2 gap-6">
							<div>
								<label for="firstName" class="block text-sm font-semibold text-neutral-700 mb-2">
									{lang === 'fr' ? 'Prénom' : 'First name'}
								</label>
								<input
									type="text"
									id="firstName"
									name="firstName"
									required
									class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
									placeholder={lang === 'fr' ? 'Jean' : 'John'}
								/>
							</div>
							<div>
								<label for="lastName" class="block text-sm font-semibold text-neutral-700 mb-2">
									{lang === 'fr' ? 'Nom' : 'Last name'}
								</label>
								<input
									type="text"
									id="lastName"
									name="lastName"
									required
									class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
									placeholder={lang === 'fr' ? 'Tremblay' : 'Smith'}
								/>
							</div>
						</div>

						<div>
							<label for="email" class="block text-sm font-semibold text-neutral-700 mb-2">
								{lang === 'fr' ? 'Courriel' : 'Email'}
							</label>
							<input
								type="email"
								id="email"
								name="email"
								required
								class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
								placeholder={lang === 'fr' ? 'vous@exemple.com' : 'you@example.com'}
							/>
						</div>

						<div>
							<label for="phone" class="block text-sm font-semibold text-neutral-700 mb-2">
								{lang === 'fr' ? 'Téléphone' : 'Phone'}
							</label>
							<input
								type="tel"
								id="phone"
								name="phone"
								required
								class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
								placeholder="514-XXX-XXXX"
							/>
						</div>

						<div>
							<label for="address" class="block text-sm font-semibold text-neutral-700 mb-2">
								{lang === 'fr' ? 'Adresse du projet' : 'Project address'}
							</label>
							<input
								type="text"
								id="address"
								name="address"
								required
								class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
								placeholder={lang === 'fr' ? 'Adresse complète à Montréal' : 'Full address in Montreal'}
							/>
						</div>

						<div>
							<label for="projectType" class="block text-sm font-semibold text-neutral-700 mb-2">
								{lang === 'fr' ? 'Type de projet' : 'Project type'}
							</label>
							<select
								id="projectType"
								name="projectType"
								required
								class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
							>
								<option value="">{lang === 'fr' ? 'Sélectionnez...' : 'Select...'}</option>
								<option value="interior">{lang === 'fr' ? 'Intérieur résidentiel' : 'Residential interior'}</option>
								<option value="exterior">{lang === 'fr' ? 'Extérieur résidentiel' : 'Residential exterior'}</option>
								<option value="both">{lang === 'fr' ? 'Intérieur et extérieur' : 'Interior and exterior'}</option>
							</select>
						</div>

						<div>
							<label for="details" class="block text-sm font-semibold text-neutral-700 mb-2">
								{lang === 'fr' ? 'Détails du projet' : 'Project details'}
							</label>
							<textarea
								id="details"
								name="details"
								rows="4"
								class="w-full px-4 py-3 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all resize-none"
								placeholder={lang === 'fr' ? 'Décrivez votre projet (pièces, superficie approximative, etc.)' : 'Describe your project (rooms, approximate area, etc.)'}
							></textarea>
						</div>

						<button
							type="submit"
							class="w-full px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-xl transition-all hover:shadow-lg hover:shadow-primary-500/40 hover:-translate-y-0.5"
						>
							{lang === 'fr' ? 'Envoyer ma demande de soumission' : 'Send my quote request'}
						</button>

						<p class="text-xs text-neutral-500 text-center">
							{lang === 'fr'
								? 'En soumettant ce formulaire, vous acceptez d\'être contacté pour discuter de votre projet.'
								: 'By submitting this form, you agree to be contacted to discuss your project.'}
						</p>
					</form>
				</div>
			</div>
		</div>
	</div>
</section>
