---
const { t, lang } = Astro.props;

const projects = [
	{
		id: 1,
		neighbourhood: 'Plateau-Mont-Royal',
		date: lang === 'fr' ? 'Janvier 2025' : 'January 2025',
		type: lang === 'fr' ? 'Intérieur complet' : 'Full interior',
		position: { top: '35%', left: '48%' }
	},
	{
		id: 2,
		neighbourhood: 'Rosemont',
		date: lang === 'fr' ? 'Décembre 2024' : 'December 2024',
		type: lang === 'fr' ? 'Cuisine & salon' : 'Kitchen & living',
		position: { top: '32%', left: '55%' }
	},
	{
		id: 3,
		neighbourhood: 'Verdun',
		date: lang === 'fr' ? 'Novembre 2024' : 'November 2024',
		type: lang === 'fr' ? 'Extérieur duplex' : 'Duplex exterior',
		position: { top: '52%', left: '42%' }
	},
	{
		id: 4,
		neighbourhood: 'Outremont',
		date: lang === 'fr' ? 'Octobre 2024' : 'October 2024',
		type: lang === 'fr' ? 'Maison complète' : 'Whole house',
		position: { top: '28%', left: '45%' }
	},
	{
		id: 5,
		neighbourhood: 'Villeray',
		date: lang === 'fr' ? 'Octobre 2024' : 'October 2024',
		type: lang === 'fr' ? 'Chambres & couloirs' : 'Bedrooms & hallways',
		position: { top: '30%', left: '52%' }
	},
	{
		id: 6,
		neighbourhood: 'NDG',
		date: lang === 'fr' ? 'Septembre 2024' : 'September 2024',
		type: lang === 'fr' ? 'Salon & salle à manger' : 'Living & dining',
		position: { top: '40%', left: '38%' }
	}
];
---

<section id="projects" class="py-20 md:py-32 bg-gradient-to-b from-white to-neutral-50">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center max-w-3xl mx-auto mb-16">
			<div class="inline-flex items-center space-x-2 px-4 py-2 bg-accent-50 rounded-full mb-6">
				<svg class="w-4 h-4 text-accent-600" fill="currentColor" viewBox="0 0 20 20">
					<path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
				</svg>
				<span class="text-sm font-semibold text-accent-700">{lang === 'fr' ? 'Stratégie gagnante' : 'Winning Strategy'}: Neighbourhood Stories Map</span>
			</div>
			<h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-neutral-900 mb-4">
				{t.neighbourhood.title}
			</h2>
			<p class="text-xl text-neutral-600 leading-relaxed">
				{t.neighbourhood.subtitle}
			</p>
		</div>

		<div class="grid lg:grid-cols-2 gap-12 items-center mb-16">
			<div class="relative">
				<div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-neutral-200">
					<div class="relative aspect-square bg-gradient-to-br from-neutral-100 to-neutral-200 p-8">
						<div class="absolute inset-0 flex items-center justify-center opacity-10">
							<svg class="w-full h-full" viewBox="0 0 400 400" fill="none">
								<path d="M200 50 L350 150 L350 350 L50 350 L50 150 Z" stroke="currentColor" stroke-width="2"/>
								<circle cx="200" cy="100" r="5" fill="currentColor"/>
								<circle cx="280" cy="180" r="5" fill="currentColor"/>
								<circle cx="150" cy="220" r="5" fill="currentColor"/>
								<circle cx="250" cy="280" r="5" fill="currentColor"/>
							</svg>
						</div>

						{projects.map((project) => (
							<button
								class="absolute w-8 h-8 bg-primary-500 hover:bg-primary-600 text-white rounded-full flex items-center justify-center shadow-lg hover:shadow-xl transition-all hover:scale-125 cursor-pointer group z-10"
								style={`top: ${project.position.top}; left: ${project.position.left};`}
								data-project-id={project.id}
							>
								<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
								</svg>
								<div class="absolute -top-2 -right-2 w-3 h-3 bg-accent-400 rounded-full animate-ping"></div>
							</button>
						))}

						<div class="absolute bottom-4 left-4 bg-white/95 backdrop-blur rounded-xl p-4 shadow-lg max-w-xs">
							<div class="flex items-center space-x-2 mb-2">
								<svg class="w-5 h-5 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
								</svg>
								<span class="font-semibold text-neutral-900">{projects.length} {lang === 'fr' ? 'projets récents' : 'recent projects'}</span>
							</div>
							<p class="text-sm text-neutral-600">
								{lang === 'fr' ? 'Cliquez sur les marqueurs pour voir les détails' : 'Click markers to see details'}
							</p>
						</div>
					</div>
				</div>
			</div>

			<div class="space-y-4">
				{projects.map((project) => (
					<div class="group bg-white hover:bg-neutral-50 rounded-2xl p-6 border border-neutral-200 hover:border-primary-200 hover:shadow-lg transition-all cursor-pointer"
					     data-project-card={project.id}>
						<div class="flex items-start justify-between mb-3">
							<div>
								<h3 class="font-display text-xl font-semibold text-neutral-900 mb-1">
									{project.neighbourhood}
								</h3>
								<p class="text-sm text-neutral-500">{project.date}</p>
							</div>
							<span class="inline-flex items-center px-3 py-1 bg-accent-100 text-accent-700 text-xs font-semibold rounded-full">
								{t.neighbourhood.recent}
							</span>
						</div>
						<p class="text-neutral-700 mb-4">{project.type}</p>
						<div class="flex items-center space-x-4">
							<div class="flex-1 grid grid-cols-3 gap-2">
								<div class="aspect-square rounded-lg bg-gradient-to-br from-neutral-200 to-neutral-300 flex items-center justify-center">
									<svg class="w-6 h-6 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
									</svg>
								</div>
								<div class="aspect-square rounded-lg bg-gradient-to-br from-neutral-200 to-neutral-300 flex items-center justify-center">
									<svg class="w-6 h-6 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
									</svg>
								</div>
								<div class="aspect-square rounded-lg bg-gradient-to-br from-neutral-200 to-neutral-300 flex items-center justify-center">
									<svg class="w-6 h-6 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
									</svg>
								</div>
							</div>
							<button class="flex-shrink-0 px-4 py-2 text-primary-600 hover:text-primary-700 font-medium text-sm group-hover:underline">
								{t.neighbourhood.viewProject} →
							</button>
						</div>
					</div>
				))}
			</div>
		</div>

		<div class="text-center">
			<a href={`${lang === 'en' ? '/en' : ''}#quote`}
			   class="inline-flex items-center px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-xl transition-all hover:shadow-lg hover:shadow-primary-500/30 hover:-translate-y-0.5">
				<svg class="mr-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
				</svg>
				<span>{t.neighbourhood.cta}</span>
			</a>
		</div>
	</div>
</section>

<style>
	@keyframes ping {
		75%, 100% {
			transform: scale(2);
			opacity: 0;
		}
	}

	.animate-ping {
		animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
	}
</style>
